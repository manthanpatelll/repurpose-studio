# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env

# typescript
*.tsbuildinfo
next-env.d.ts

# python venv for the optional SFX engine (scripts/sfx-engine)
**/.venv/
**/__pycache__/

# local repurpose runtime data (also written outside the repo:
# ~/Downloads/repurpose-projects, ~/Downloads/repurpose-overlays,
# and $TMPDIR/repurpose-proxy — kept here in case a user relocates them)
/.repurpose-data/
